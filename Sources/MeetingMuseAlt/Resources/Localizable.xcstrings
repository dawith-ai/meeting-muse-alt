  "strings" : {
    "Meeting Muse — Alt" : {
      "shouldTranslate" : false
    },
    "'녹음 시작' 버튼을 누르거나, 줌·구글 미트가 시작되면 자동으로 감지됩니다." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Press the 'Start Recording' button, or recording begins automatically when Zoom or Google Meet starts."
          }
        },
